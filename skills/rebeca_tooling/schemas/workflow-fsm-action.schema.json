{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workflow-fsm-action",
  "description": "FSM controller action output schema for the Step01→Step08 pipeline.",
  "type": "object",
  "required": [
    "status",
    "current_state",
    "next_state",
    "action",
    "reason_code",
    "required_artifacts",
    "missing_artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "error", "retry", "blocked"],
      "description": "FSM execution status."
    },
    "current_state": {
      "type": "string",
      "description": "State identifier (e.g., 'initialized', 'triaged', 'abstracted')."
    },
    "next_state": {
      "type": "string",
      "description": "Predicted next state after the action succeeds."
    },
    "action": {
      "type": "object",
      "required": ["type", "step", "agent", "inputs"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["run_step", "refine_step", "finish", "block", "skip", "error"],
          "description": "Machine-actionable operation type."
        },
        "step": {
          "type": "string",
          "enum": [
            "step01_init",
            "step02_triage",
            "step03_abstraction",
            "step04_mapping",
            "step05_synthesis",
            "step06_verification_gate",
            "step07_packaging",
            "step08_reporting",
            "none"
          ],
          "description": "Step identifier."
        },
        "agent": {
          "type": "string",
          "enum": [
            "init_exec",
            "triage_exec",
            "abstraction_agent",
            "mapping_agent",
            "synthesis_agent",
            "verification_exec",
            "packaging_exec",
            "reporting_exec",
            "none"
          ],
          "description": "Subagent to invoke."
        },
        "inputs": {
          "type": "object",
          "description": "Verbatim inputs to pass to the agent.",
          "additionalProperties": true
        }
      }
    },
    "reason_code": {
      "type": "string",
      "description": "Human-readable code for transition logic (e.g., 'artifact_missing', 'rmc_failed', 'score_below_threshold')."
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of canonical filenames required to exist for this state to be valid."
    },
    "missing_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of required artifacts currently missing from the work directory."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "properties": { "type": { "const": "refine_step" } }
          }
        }
      },
      "then": {
        "properties": {
          "action": {
            "properties": {
              "inputs": {
                "required": [
                  "prior_artifact_path",
                  "issue_class",
                  "issue_detail",
                  "attempt_index",
                  "budget_remaining"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "properties": { "type": { "enum": ["finish", "block", "skip"] } }
          }
        }
      },
      "then": {
        "properties": {
          "action": {
            "properties": {
              "step": { "const": "none" },
              "agent": { "const": "none" }
            }
          }
        }
      }
    }
  ]
}
