{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "triage-agent contract",
  "description": "Input and output schemas for the triage-agent (Step02).",

  "definitions": {
    "ErrorEnvelope": {
      "type": "object",
      "required": ["status", "phase", "agent", "message"],
      "additionalProperties": false,
      "properties": {
        "status":  { "type": "string", "const": "error" },
        "phase":   { "type": "string", "const": "step02" },
        "agent":   { "type": "string", "const": "triage-agent" },
        "message": { "type": "string", "minLength": 1 }
      }
    },

    "FallbackMapping": {
      "type": "object",
      "required": ["rule_id", "provisional_property", "confidence",
                   "assumptions", "requires_manual_review", "mapping_path"],
      "additionalProperties": false,
      "properties": {
        "rule_id":               { "type": "string" },
        "provisional_property":  { "type": "string" },
        "confidence":            { "type": "string", "enum": ["high", "medium", "low"] },
        "assumptions":           { "type": "array", "items": { "type": "string" } },
        "requires_manual_review":{ "type": "boolean" },
        "mapping_path":          { "type": "string", "const": "colreg-fallback" }
      }
    }
  },

  "input": {
    "type": "object",
    "required": ["rule_id", "legata_path"],
    "additionalProperties": false,
    "properties": {
      "rule_id":     { "type": "string", "minLength": 1 },
      "legata_path": { "type": "string", "minLength": 1 },
      "colreg_text": {
        "type": "string",
        "description": "Raw COLREG source text; required when fallback is anticipated."
      }
    }
  },

  "output": {
    "oneOf": [
      {
        "type": "object",
        "required": ["status", "rule_id", "classification", "routing"],
        "additionalProperties": false,
        "properties": {
          "status":  { "type": "string", "const": "ok" },
          "rule_id": { "type": "string" },

          "classification": {
            "type": "object",
            "required": ["status", "clause_count", "evidence", "defects", "next_action"],
            "additionalProperties": false,
            "properties": {
              "status": {
                "type": "string",
                "enum": ["formalized", "incomplete", "incorrect",
                         "not-formalized", "todo-placeholder"]
              },
              "clause_count": { "type": "integer", "minimum": 0 },
              "evidence":     { "type": "array", "items": { "type": "string" } },
              "defects":      { "type": "array", "items": { "type": "string" } },
              "next_action":  { "type": "string" }
            }
          },

          "routing": {
            "type": "object",
            "required": ["path", "eligible_for_mapping"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "enum": ["normal", "repair", "colreg-fallback", "skip"],
                "description": "Downstream handling path chosen by triage."
              },
              "eligible_for_mapping": { "type": "boolean" },
              "fallback_mapping": {
                "$ref": "#/definitions/FallbackMapping",
                "description": "Populated only when path == colreg-fallback."
              }
            }
          }
        }
      },
      { "$ref": "#/definitions/ErrorEnvelope" }
    ]
  }
}
