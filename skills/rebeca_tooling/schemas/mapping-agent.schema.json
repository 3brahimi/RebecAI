{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mapping-agent contract",
  "description": "Input and output schemas for the mapping-agent (Step04).",

  "definitions": {
    "ErrorEnvelope": {
      "type": "object",
      "required": ["status", "phase", "agent", "message"],
      "additionalProperties": false,
      "properties": {
        "status":  { "type": "string", "const": "error" },
        "phase":   { "type": "string", "const": "step04" },
        "agent":   { "type": "string", "const": "mapping-agent" },
        "message": { "type": "string", "minLength": 1 }
      }
    },

    "Artifact": {
      "type": "object",
      "required": ["path", "content"],
      "additionalProperties": false,
      "properties": {
        "path":    { "type": "string", "description": "Absolute path the file was written to." },
        "content": { "type": "string", "description": "Full text content of the generated file." }
      }
    },

    "VariableEntry": {
      "type": "object",
      "required": ["legata_concept", "rebeca_name", "rebeca_type", "define_alias", "source"],
      "additionalProperties": false,
      "properties": {
        "legata_concept": { "type": "string" },
        "rebeca_name":    { "type": "string" },
        "rebeca_type":    { "type": "string", "enum": ["boolean", "int"] },
        "bounds": {
          "type": "object",
          "required": ["min", "max"],
          "additionalProperties": false,
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          }
        },
        "define_alias":  { "type": "string" },
        "source":        { "type": "string", "enum": ["condition", "exclusion", "assurance", "inferred"] }
      }
    },

    "ActorEntry": {
      "type": "object",
      "required": ["legata_actor", "rebeca_class", "rebeca_instance"],
      "additionalProperties": false,
      "properties": {
        "legata_actor":    { "type": "string" },
        "rebeca_class":    { "type": "string" },
        "rebeca_instance": { "type": "string" }
      }
    },

    "AbstractionSummary": {
      "type": "object",
      "required": ["naming_contract", "actor_map", "variable_map"],
      "additionalProperties": true,
      "properties": {
        "naming_contract": { "type": "object" },
        "actor_map":       { "type": "array", "items": { "$ref": "#/definitions/ActorEntry" } },
        "variable_map":    { "type": "array", "items": { "$ref": "#/definitions/VariableEntry" } }
      }
    }
  },

  "input": {
    "type": "object",
    "required": ["rule_id", "legata_input", "abstraction_summary", "output_dir"],
    "additionalProperties": false,
    "properties": {
      "rule_id":             { "type": "string", "minLength": 1 },
      "legata_input":         { "type": "string", "minLength": 1 },
      "abstraction_summary": { "$ref": "#/definitions/AbstractionSummary" },
      "output_dir":          { "type": "string", "minLength": 1 }
    }
  },

  "output": {
    "oneOf": [
      {
        "type": "object",
        "required": ["status", "rule_id", "model_artifact", "property_artifact", "open_assumptions"],
        "additionalProperties": false,
        "properties": {
          "status":            { "type": "string", "const": "ok" },
          "rule_id":           { "type": "string" },
          "model_artifact":    { "$ref": "#/definitions/Artifact" },
          "property_artifact": { "$ref": "#/definitions/Artifact" },
          "open_assumptions":  { "type": "array", "items": { "type": "string" } }
        }
      },
      { "$ref": "#/definitions/ErrorEnvelope" }
    ]
  }
}
